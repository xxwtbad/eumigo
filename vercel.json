{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["hnd1"],
  "env": {
    "TZ": "Asia/Shanghai"
  },
  "crons": [
    {
      "schedule": "0 0 * * 0",
      "path": "/api/cron/clean-temp-images"
    }
  ],
  "headers": [
    {
      "source": "/api/music/stream",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/api/music/lyrics",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/api/music/lrc-text",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
